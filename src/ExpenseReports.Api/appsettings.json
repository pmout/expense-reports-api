{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Fatal",
        "Microsoft.AspNetCore.DataProtection": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=expense_reports;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "expense-reports-api",
    "Audience": "expense-reports-clients",
    "SigningKey": "dev-only-signing-key-change-me-0123456789abcdef",
    "ExpiryMinutes": 60
  },
  "Database": {
    "MigrateOnStartup": true,
    "SeedOnStartup": false
  },
  "AllowedHosts": "*"
}
